{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read",
      "Write",
      "Edit",
      "Bash(tsc --noEmit)",
      "Bash(eslint .)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Write(**/node_modules/**)",
      "Write(**/dist/**)",
      "Write(**/out/**)",
      "Write(**/*.vsix)"
    ]
  }
}
